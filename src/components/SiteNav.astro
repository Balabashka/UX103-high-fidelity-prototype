---
const pathname = Astro.url.pathname;

interface Props {
	user: { id: string; username: string } | null;
}

const { user } = Astro.props;

const links = [
	{ href: '/', label: 'Home' },
	{ href: '/asynchronous', label: 'Asynchronous' },
	{ href: '/synchronous', label: 'Synchronous' },
	{ href: '/case-study', label: 'Case Study' },
	{ href: '/discussion', label: 'Discussion board' },
] as const;

function isActive(href: string) {
	return href === '/' ? pathname === '/' : pathname === href;
}
---

<nav class="site-nav" aria-label="Main">
	<div class="nav-start">
		<a class="brand" href="/">UXplore</a>
		<p class="tagline">Virtual classroom</p>
	</div>
	<ul class="nav-links">
		{
			links.map(({ href, label }) => (
				<li>
					<a href={href} aria-current={isActive(href) ? 'page' : undefined}>
						{label}
					</a>
				</li>
			))
		}
	</ul>
	<div class="nav-auth">
		{
			user ? (
				<>
					<span class="nav-user" title={user.username}>
						@{user.username}
					</span>
					<button type="button" class="nav-logout" id="nav-logout">
						Log out
					</button>
				</>
			) : (
				<>
					<a class="nav-auth-link" href="/login" aria-current={pathname === '/login' ? 'page' : undefined}>
						Log in
					</a>
					<a class="nav-auth-link nav-auth-link--primary" href="/register" aria-current={pathname === '/register' ? 'page' : undefined}>
						Register
					</a>
				</>
			)
		}
	</div>
</nav>

<script>
	document.getElementById('nav-logout')?.addEventListener('click', async () => {
		await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
		window.location.href = '/';
	});
</script>

<style>
	.site-nav {
		position: sticky;
		top: 0;
		z-index: 100;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1rem 1.5rem;
		padding: 0.85rem 1.25rem;
		background: rgba(255, 255, 255, 0.92);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border, #e7e5e4);
		box-shadow: 0 4px 20px rgba(28, 25, 23, 0.06);
		font-size: 0.92rem;
	}
	.nav-start {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		line-height: 1.2;
		min-width: 0;
	}
	.brand {
		font-weight: 750;
		font-size: 1.1rem;
		letter-spacing: -0.03em;
		text-decoration: none;
		color: var(--text, #1c1917);
	}
	.tagline {
		margin: 0;
		font-size: 0.75rem;
		color: var(--muted, #57534e);
	}
	.nav-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-end;
		gap: 0.35rem 0.25rem;
		list-style: none;
		margin: 0;
		padding: 0;
		flex: 1;
	}
	.nav-links li a {
		display: inline-block;
		padding: 0.4rem 0.65rem;
		border-radius: 8px;
		color: var(--text, #1c1917);
		text-decoration: none;
	}
	.nav-links li a:hover {
		background: #f5f3ef;
	}
	.nav-links a[aria-current='page'] {
		font-weight: 650;
		background: #ccfbf1;
		color: #115e59;
	}
	.nav-auth {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem 0.75rem;
	}
	.nav-user {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--muted, #57534e);
		max-width: 10rem;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.nav-logout {
		font: inherit;
		font-size: 0.85rem;
		font-weight: 600;
		color: #115e59;
		background: var(--accent-soft, #ccfbf1);
		border: 1px solid #5eead4;
		border-radius: 8px;
		padding: 0.35rem 0.65rem;
		cursor: pointer;
	}
	.nav-logout:hover {
		background: #99f6e4;
	}
	.nav-auth-link {
		font-size: 0.85rem;
		font-weight: 600;
		text-decoration: none;
		color: var(--text, #1c1917);
		padding: 0.35rem 0.65rem;
		border-radius: 8px;
	}
	.nav-auth-link:hover {
		background: #f5f3ef;
	}
	.nav-auth-link--primary {
		background: var(--accent, #0f766e);
		color: #fff;
	}
	.nav-auth-link--primary:hover {
		background: var(--accent-hover, #0d9488);
		color: #fff;
	}
	.nav-auth a[aria-current='page'] {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}
</style>
