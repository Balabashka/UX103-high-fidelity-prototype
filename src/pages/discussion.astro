---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Discussion board | UXplore">
	<header class="page-header">
		<p class="section-label">Community</p>
		<h1>Discussion board</h1>
		<p class="lead">
			Ask questions, share ideas, and connect with classmates. Static prototype — real posting comes when the backend is wired up.
		</p>
	</header>

	<!-- Forum chrome -->
	<div class="forum-layout">

		<!-- Top bar: category filters + search -->
		<div class="forum-topbar">
			<div class="forum-cats" role="group" aria-label="Filter by category">
				<button class="forum-cat forum-cat--active" data-cat="all">All threads</button>
				<button class="forum-cat" data-cat="arvr">
					<span class="forum-cat__dot" style="background:#0d9488"></span>AR / VR
				</button>
				<button class="forum-cat" data-cat="project">
					<span class="forum-cat__dot" style="background:#7c3aed"></span>Smart Campus
				</button>
				<button class="forum-cat" data-cat="general">
					<span class="forum-cat__dot" style="background:#d97706"></span>General
				</button>
			</div>

			<div class="forum-search-wrap">
				<svg class="forum-search-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
					<circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.5"/>
					<path d="M10 10.5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
				</svg>
				<input class="forum-search-input" type="search" placeholder="Search threads…" id="forum-search" aria-label="Search threads" />
			</div>
		</div>

		<!-- Thread list -->
		<div class="forum-threads" id="forum-threads" role="feed">

			<article class="fthread" data-cat="arvr">
				<div class="fthread__avatar fthread__avatar--teal" aria-hidden="true">A</div>
				<div class="fthread__body">
					<div class="fthread__meta">
						<span class="fthread__author">Alex</span>
						<span class="fthread__cat fthread__cat--teal">AR / VR</span>
						<span class="fthread__time">2h ago</span>
					</div>
					<h2 class="fthread__title">IKEA Place vs in-store: is that always "AR"?</h2>
					<p class="fthread__snippet">For the quiz I'm tying it to "overlay on real environment" — does that match what others wrote? The IKEA Place app seems like a clear case but I want to double-check before my submission.</p>
					<div class="fthread__footer">
						<span class="fthread__stat">
							<svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2C4.134 2 1 4.686 1 8c0 1.385.511 2.659 1.363 3.671L1.5 14l2.653-.863A7.06 7.06 0 0 0 8 14c3.866 0 7-2.686 7-6s-3.134-6-7-6Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
							6 replies
						</span>
						<button class="fthread__reply-btn" disabled>Reply</button>
					</div>
				</div>
			</article>

			<article class="fthread" data-cat="project">
				<div class="fthread__avatar fthread__avatar--violet" aria-hidden="true">B</div>
				<div class="fthread__body">
					<div class="fthread__meta">
						<span class="fthread__author">Bo</span>
						<span class="fthread__cat fthread__cat--violet">Smart Campus</span>
						<span class="fthread__time">5h ago</span>
					</div>
					<h2 class="fthread__title">Random group + friend request both checked?</h2>
					<p class="fthread__snippet">Does the sign-up form prioritize random assignment or should we email the prof? My friend and I are in different sections and both checked both options.</p>
					<div class="fthread__footer">
						<span class="fthread__stat">
							<svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2C4.134 2 1 4.686 1 8c0 1.385.511 2.659 1.363 3.671L1.5 14l2.653-.863A7.06 7.06 0 0 0 8 14c3.866 0 7-2.686 7-6s-3.134-6-7-6Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
							3 replies
						</span>
						<button class="fthread__reply-btn" disabled>Reply</button>
					</div>
				</div>
			</article>

			<article class="fthread" data-cat="general">
				<div class="fthread__avatar fthread__avatar--amber" aria-hidden="true">C</div>
				<div class="fthread__body">
					<div class="fthread__meta">
						<span class="fthread__author">Casey</span>
						<span class="fthread__cat fthread__cat--amber">General</span>
						<span class="fthread__time">1d ago</span>
					</div>
					<h2 class="fthread__title">Office hours Zoom link?</h2>
					<p class="fthread__snippet">The synced page still says "paste URL" — did I miss it somewhere in the syllabus? Checked under Week 3 resources too.</p>
					<div class="fthread__footer">
						<span class="fthread__stat">
							<svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2C4.134 2 1 4.686 1 8c0 1.385.511 2.659 1.363 3.671L1.5 14l2.653-.863A7.06 7.06 0 0 0 8 14c3.866 0 7-2.686 7-6s-3.134-6-7-6Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
							12 replies
						</span>
						<button class="fthread__reply-btn" disabled>Reply</button>
					</div>
				</div>
			</article>

			<article class="fthread" data-cat="project">
				<div class="fthread__avatar fthread__avatar--rose" aria-hidden="true">D</div>
				<div class="fthread__body">
					<div class="fthread__meta">
						<span class="fthread__author">Dana</span>
						<span class="fthread__cat fthread__cat--violet">Smart Campus</span>
						<span class="fthread__time">2d ago</span>
					</div>
					<h2 class="fthread__title">IoT + study rooms: camera sensors?</h2>
					<p class="fthread__snippet">Team is debating privacy vs occupancy detection — are there examples from lecture we can reference for the proposal? Specifically around anonymised sensor data.</p>
					<div class="fthread__footer">
						<span class="fthread__stat">
							<svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2C4.134 2 1 4.686 1 8c0 1.385.511 2.659 1.363 3.671L1.5 14l2.653-.863A7.06 7.06 0 0 0 8 14c3.866 0 7-2.686 7-6s-3.134-6-7-6Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
							4 replies
						</span>
						<button class="fthread__reply-btn" disabled>Reply</button>
					</div>
				</div>
			</article>

			<p class="forum-empty" id="forum-empty" hidden>No threads match your filter.</p>
		</div>

		<!-- Composer -->
		<div class="forum-composer">
			<div class="forum-composer__header">
				<div class="fthread__avatar fthread__avatar--teal" aria-hidden="true" style="width:2rem;height:2rem;font-size:0.8rem">Y</div>
				<input
					class="forum-composer__input"
					type="text"
					placeholder="Start a new thread… (disabled in prototype)"
					disabled
					aria-label="New thread title"
				/>
				<button class="btn forum-composer__btn" disabled>Post</button>
			</div>
		</div>

	</div>
</Layout>

<style>
/* ── Forum layout ─────────────────────────────────────────────────────────── */
.forum-layout {
	display: flex;
	flex-direction: column;
	gap: 0;
}

/* ── Top bar ──────────────────────────────────────────────────────────────── */
.forum-topbar {
	display: flex;
	align-items: center;
	justify-content: space-between;
	flex-wrap: wrap;
	gap: 0.75rem 1rem;
	padding: 0.6rem 0.85rem;
	background: rgba(255,255,255,0.75);
	backdrop-filter: blur(8px);
	border: 1px solid rgba(231,229,228,0.85);
	border-radius: var(--radius) var(--radius) 0 0;
	border-bottom: none;
}

.forum-cats {
	display: flex;
	flex-wrap: wrap;
	gap: 0.3rem;
	align-items: center;
}

.forum-cat {
	display: inline-flex;
	align-items: center;
	gap: 0.4rem;
	padding: 0.3rem 0.85rem;
	font: inherit;
	font-size: 0.82rem;
	font-weight: 600;
	color: var(--muted);
	background: transparent;
	border: 1.5px solid transparent;
	border-radius: 999px;
	cursor: pointer;
	transition: background 0.15s, color 0.15s, border-color 0.15s;
}
.forum-cat:hover {
	background: rgba(0,0,0,0.04);
	color: var(--text);
}
.forum-cat--active {
	background: var(--accent-soft);
	color: #115e59;
	border-color: #5eead4;
}
.forum-cat__dot {
	display: inline-block;
	width: 7px;
	height: 7px;
	border-radius: 50%;
	flex-shrink: 0;
}

.forum-search-wrap {
	position: relative;
	flex: 0 0 auto;
}
.forum-search-icon {
	position: absolute;
	left: 0.65rem;
	top: 50%;
	transform: translateY(-50%);
	width: 13px;
	height: 13px;
	color: var(--muted);
	pointer-events: none;
}
.forum-search-input {
	width: 14rem;
	padding: 0.4rem 0.75rem 0.4rem 2rem;
	font: inherit;
	font-size: 0.82rem;
	border: 1.5px solid var(--border);
	border-radius: 999px;
	background: rgba(255,255,255,0.9);
	color: var(--text);
	outline: none;
	transition: border-color 0.15s;
	-webkit-appearance: none;
}
.forum-search-input:focus { border-color: #5eead4; }
.forum-search-input::placeholder { color: #a8a29e; }

/* ── Thread list ──────────────────────────────────────────────────────────── */
.forum-threads {
	display: flex;
	flex-direction: column;
	background: rgba(255,255,255,0.6);
	border: 1px solid rgba(231,229,228,0.85);
	border-bottom: none;
}

.fthread {
	display: grid;
	grid-template-columns: 2.75rem 1fr;
	gap: 0 0.9rem;
	padding: 1.1rem 1.1rem 1rem;
	border-bottom: 1px solid rgba(231,229,228,0.7);
	transition: background 0.15s;
	cursor: default;
}
.fthread:last-of-type { border-bottom: none; }
.fthread:hover { background: rgba(255,255,255,0.85); }

.fthread__avatar {
	width: 2.75rem;
	height: 2.75rem;
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 0.95rem;
	font-weight: 700;
	color: #fff;
	flex-shrink: 0;
	margin-top: 0.1rem;
}
.fthread__avatar--teal   { background: #0d9488; }
.fthread__avatar--violet { background: #7c3aed; }
.fthread__avatar--amber  { background: #d97706; }
.fthread__avatar--rose   { background: #e11d48; }

.fthread__body { min-width: 0; }

.fthread__meta {
	display: flex;
	align-items: center;
	flex-wrap: wrap;
	gap: 0.4rem;
	margin-bottom: 0.3rem;
}
.fthread__author {
	font-size: 0.85rem;
	font-weight: 700;
	color: var(--text);
}
.fthread__time {
	font-size: 0.78rem;
	color: var(--muted);
}
.fthread__cat {
	display: inline-flex;
	align-items: center;
	font-size: 0.7rem;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.05em;
	padding: 0.15rem 0.55rem;
	border-radius: 999px;
}
.fthread__cat--teal   { background: #ccfbf1; color: #0f766e; }
.fthread__cat--violet { background: #ede9fe; color: #6d28d9; }
.fthread__cat--amber  { background: #fef3c7; color: #b45309; }

.fthread__title {
	font-size: 0.98rem;
	font-weight: 650;
	line-height: 1.35;
	margin: 0 0 0.35rem;
	color: var(--text);
	letter-spacing: -0.01em;
}
.fthread__snippet {
	font-size: 0.875rem;
	color: var(--muted);
	line-height: 1.5;
	margin: 0 0 0.75rem;
	/* clamp to 2 lines */
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

.fthread__footer {
	display: flex;
	align-items: center;
	gap: 1rem;
}
.fthread__stat {
	display: inline-flex;
	align-items: center;
	gap: 0.35rem;
	font-size: 0.78rem;
	color: var(--muted);
	font-weight: 500;
}
.fthread__stat svg {
	width: 13px;
	height: 13px;
	flex-shrink: 0;
}
.fthread__reply-btn {
	font: inherit;
	font-size: 0.78rem;
	font-weight: 600;
	color: var(--accent);
	background: transparent;
	border: none;
	padding: 0;
	cursor: not-allowed;
	opacity: 0.5;
}

.forum-empty {
	padding: 2.5rem 1.25rem;
	text-align: center;
	color: var(--muted);
	font-size: 0.9rem;
}

/* ── Composer ─────────────────────────────────────────────────────────────── */
.forum-composer {
	padding: 0.85rem 1rem;
	background: rgba(255,255,255,0.75);
	backdrop-filter: blur(8px);
	border: 1px solid rgba(231,229,228,0.85);
	border-radius: 0 0 var(--radius) var(--radius);
}
.forum-composer__header {
	display: flex;
	align-items: center;
	gap: 0.75rem;
}
.forum-composer__input {
	flex: 1;
	padding: 0.55rem 0.85rem;
	font: inherit;
	font-size: 0.9rem;
	border: 1.5px solid var(--border);
	border-radius: 999px;
	background: rgba(250,250,249,0.8);
	color: var(--text);
	outline: none;
	cursor: not-allowed;
	opacity: 0.6;
}
.forum-composer__btn {
	flex-shrink: 0;
	opacity: 0.5;
	cursor: not-allowed;
	border-radius: 999px;
	padding: 0.5rem 1.25rem;
	font-size: 0.88rem;
}

@media (max-width: 560px) {
	.forum-topbar {
		flex-direction: column;
		align-items: flex-start;
	}
	.forum-search-input { width: 100%; }
	.forum-search-wrap  { width: 100%; }
	.fthread { grid-template-columns: 2.25rem 1fr; gap: 0 0.65rem; }
}
</style>

<script>
	const cats     = document.querySelectorAll<HTMLButtonElement>('.forum-cat');
	const threads  = document.querySelectorAll<HTMLElement>('.fthread');
	const searchEl = document.getElementById('forum-search') as HTMLInputElement | null;
	const emptyEl  = document.getElementById('forum-empty') as HTMLElement | null;

	let activeCat = 'all';

	function applyFilters(): void {
		const q = searchEl?.value.trim().toLowerCase() ?? '';
		let visible = 0;
		threads.forEach(t => {
			const catMatch = activeCat === 'all' || t.dataset['cat'] === activeCat;
			const text = t.textContent?.toLowerCase() ?? '';
			const searchMatch = !q || text.includes(q);
			const show = catMatch && searchMatch;
			t.hidden = !show;
			if (show) visible++;
		});
		if (emptyEl) emptyEl.hidden = visible > 0;
	}

	cats.forEach(btn => {
		btn.addEventListener('click', () => {
			cats.forEach(b => b.classList.remove('forum-cat--active'));
			btn.classList.add('forum-cat--active');
			activeCat = btn.dataset['cat'] ?? 'all';
			applyFilters();
		});
	});

	searchEl?.addEventListener('input', applyFilters);
</script>