---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Synchronous | UXplore">
	<header class="page-header">
		<p class="section-label">Learn together</p>
		<h1>Synchronous</h1>
		<p class="lead">
			Join live sessions, connect with educators, and share feedback on your learning experience.
		</p>
	</header>

	<!-- ── Live Session ───────────────────────────────────────────────── -->
	<section class="card" aria-labelledby="live-heading">
		<h2 id="live-heading">Live Session</h2>
		<p>Join your scheduled class live via Zoom. Make sure you're logged in to your Zoom account before clicking the link.</p>
		<a class="zoom-btn" href="https://zoom.us/j/your-meeting-id" target="_blank" rel="noopener noreferrer">
			<svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
				<rect width="24" height="24" rx="5" fill="#2D8CFF"/>
				<path d="M4 8.5A1.5 1.5 0 015.5 7h7A1.5 1.5 0 0114 8.5v7A1.5 1.5 0 0112.5 17h-7A1.5 1.5 0 014 15.5v-7zM16 10.2l3.6-2.4A.5.5 0 0120 8.2v7.6a.5.5 0 01-.8.4L16 13.8V10.2z" fill="#fff"/>
			</svg>
			Join Zoom Class
		</a>
		<p class="helper" style="margin-top:0.75rem;">Replace the link above with your actual recurring Zoom meeting URL.</p>
	</section>

	<!-- ── Office Hours / Educators ───────────────────────────────────── -->
	<section class="card" aria-labelledby="educators-heading">
		<h2 id="educators-heading">Office Hours &amp; Educator Contact</h2>
		<p class="helper" style="margin-bottom:1.25rem;">Reach out directly by email or drop in during any of the office hours below.</p>

		<div class="educators-grid">
			<div class="educator-card">
				<div class="educator-card__header">
					<span class="educator-avatar">JL</span>
					<div>
						<p class="educator-name">Jamie Liattis</p>
						<a class="educator-email" href="mailto:123myUXplore@gmail.com">123myUXplore@gmail.com</a>
					</div>
				</div>
				<ul class="educator-hours">
					<li><span class="day">Monday</span> 3:30 pm – 5:00 pm</li>
					<li><span class="day">Thursday</span> 5:00 pm – 7:00 pm</li>
				</ul>
			</div>

			<div class="educator-card">
				<div class="educator-card__header">
					<span class="educator-avatar">SC</span>
					<div>
						<p class="educator-name">Sue Cumberbach</p>
						<a class="educator-email" href="mailto:456myUXplore@gmail.com">456myUXplore@gmail.com</a>
					</div>
				</div>
				<ul class="educator-hours">
					<li><span class="day">Tuesday</span> 9:00 am – 10:00 am</li>
					<li><span class="day">Wednesday</span> 7:00 pm – 9:00 pm</li>
				</ul>
			</div>

			<div class="educator-card">
				<div class="educator-card__header">
					<span class="educator-avatar">ZK</span>
					<div>
						<p class="educator-name">Zara Khar</p>
						<a class="educator-email" href="mailto:1020myUXplore@gmail.com">1020myUXplore@gmail.com</a>
					</div>
				</div>
				<ul class="educator-hours">
					<li><span class="day">Friday</span> 4:00 pm – 7:00 pm</li>
				</ul>
			</div>

			<div class="educator-card">
				<div class="educator-card__header">
					<span class="educator-avatar">JS</span>
					<div>
						<p class="educator-name">Jennifer Sinclair</p>
