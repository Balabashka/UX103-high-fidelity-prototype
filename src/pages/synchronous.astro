---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Synchronous | UXplore">
	<header class="page-header">
		<p class="section-label">Learn together</p>
		<h1>Synchronous</h1>
		<p class="lead">
			Live sessions on the left, people and community resources on the right—swap in real Zoom links and office-hour
			times when you have them.
		</p>
	</header>

	<div class="layout-split--50">
		<div class="split-stack">
			<section class="card">
				<h2>Live session</h2>
				<p class="prose">
					<strong>Zoom link to join:</strong>
					<em>(paste your meeting URL)</em>
				</p>
				<p class="helper">Tip: add the recurring schedule (day/time/time zone) so students know when to show up.</p>
			</section>

			<section class="card">
				<h2>Office hours</h2>
				<p class="prose">
					Use this block for feedback and questions—<em>add times, location (virtual room), and how to book a slot</em>.
				</p>
			</section>
		</div>

		<div class="split-stack">
			<section class="card">
				<h2>Volunteer instructors</h2>
				<p class="prose">
					<strong>Email list / contact:</strong>
					<em>volunteer-profs@example.edu</em> <span class="helper">(replace with a real address or form)</span>
				</p>
				<p class="prose">Short note on what students should put in the subject line helps keep inboxes manageable.</p>
			</section>

			<section class="card">
				<h2>Class discussion</h2>
				<p class="prose">
					For async conversations with classmates, use the
					<a href="/discussion">discussion board</a>—keep live sessions focused and follow up in the forum.
				</p>
			</section>
		</div>
	</div>
</Layout>
