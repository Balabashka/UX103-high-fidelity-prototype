		</div>
		<p class="helper" style="margin-top:0.75rem;">
			Replace this placeholder with an embedded Google Calendar or upload a schedule image.
		</p>
	</section>

	<!-- ── Educator Review ────────────────────────────────────────────── -->
	<section class="card" aria-labelledby="review-heading">
		<h2 id="review-heading">Educator Review</h2>
		<p>Rank how you feel about the content on this website and your learning experience overall.</p>
		<p class="helper" style="margin-bottom:1.5rem;">Scale: 1 = Very poor &nbsp;·&nbsp; 3 = Indifferent &nbsp;·&nbsp; 5 = Excellent</p>

		<form class="review-form" id="review-form" novalidate>
			<div class="form-row">
				<label for="reviewer-name">1. Your full name</label>
				<input type="text" id="reviewer-name" name="reviewerName" placeholder="First and last name" autocomplete="name" required />
			</div>

			<div class="form-row">
				<label for="teacher-name">2. Educator's name</label>
				<select id="teacher-name" name="teacherName" required>
					<option value="" disabled selected>Select an educator…</option>
					<option>Jamie Liattis</option>
					<option>Sue Cumberbach</option>
					<option>Zara Khar</option>
					<option>Jennifer Sinclair</option>
				</select>
			</div>

			<div class="form-row">
				<label>3. I feel the educator has offered opportunity to ask questions and challenge ideas</label>
				<div class="rating-scale" role="radiogroup" aria-label="Question 3 rating">
					{[1,2,3,4,5].map(n => (
						<label class="rating-option">
							<input type="radio" name="q3" value={n} required />
							<span class="rating-option__num">{n}</span>
						</label>
					))}
					<span class="rating-label rating-label--lo">Poor</span>
					<span class="rating-label rating-label--hi">Excellent</span>
				</div>
			</div>

			<div class="form-row">
				<label>4. This educator has conducted interactive learning experiences during class time</label>
				<div class="rating-scale" role="radiogroup" aria-label="Question 4 rating">
					{[1,2,3,4,5].map(n => (
						<label class="rating-option">
							<input type="radio" name="q4" value={n} required />
							<span class="rating-option__num">{n}</span>
						</label>
					))}
					<span class="rating-label rating-label--lo">Poor</span>
					<span class="rating-label rating-label--hi">Excellent</span>
				</div>
			</div>

			<div class="form-row">
				<label>5. I feel encouraged and motivated to return to synchronous lessons after each class</label>
				<div class="rating-scale" role="radiogroup" aria-label="Question 5 rating">
					{[1,2,3,4,5].map(n => (
						<label class="rating-option">
							<input type="radio" name="q5" value={n} required />
							<span class="rating-option__num">{n}</span>
						</label>
					))}
					<span class="rating-label rating-label--lo">Poor</span>
					<span class="rating-label rating-label--hi">Excellent</span>
				</div>
			</div>

			<div class="form-row">
				<label for="extra-feedback">6. Additional feedback for your educator <span class="helper">(only they will receive these suggestions)</span></label>
				<textarea id="extra-feedback" name="extraFeedback" rows="4" placeholder="Share any thoughts, suggestions, or praise…"></textarea>
			</div>

			<div class="form-actions">
				<button class="btn" type="submit">Submit review</button>
				<p class="review-confirm" id="review-confirm" hidden>✓ Thank you — your feedback has been submitted.</p>
			</div>
		</form>
	</section>
</Layout>

<script>
  const form = document.getElementById('review-form') as HTMLFormElement | null;
  const confirm = document.getElementById('review-confirm') as HTMLElement | null;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    // Replace with real form submission (e.g. fetch to an API endpoint)
    if (confirm) {
      confirm.hidden = false;
      (form.querySelector('button[type="submit"]') as HTMLButtonElement).disabled = true;
    }
  });
</script>

<style>
	/* ── Zoom button ─────────────────────────────────────────────────── */
	.zoom-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		background: #2D8CFF;
		color: #fff;
		font-weight: 700;
		font-size: 0.95rem;
		padding: 0.65rem 1.25rem;
		border-radius: 8px;
		text-decoration: none;
		margin-top: 0.75rem;
		transition: opacity 0.15s, transform 0.15s;
	}
	.zoom-btn svg {
		width: 24px;
		height: 24px;
		flex-shrink: 0;
	}
	.zoom-btn:hover { opacity: 0.9; transform: translateY(-1px); }

	/* ── Educators grid ──────────────────────────────────────────────── */
	.educators-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
	}
	@media (max-width: 600px) {
		.educators-grid { grid-template-columns: 1fr; }
	}

	.educator-card {
		background: rgba(250,250,249,0.8);
		border: 1px solid var(--border);
		border-radius: var(--radius-sm);
		padding: 1rem;
	}

	.educator-card__header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
	}

	.educator-avatar {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 50%;
		background: var(--accent);
		color: #fff;
		font-weight: 700;
		font-size: 0.85rem;
		flex-shrink: 0;
	}

	.educator-name {
		margin: 0 0 0.1rem;
		font-weight: 600;
		font-size: 0.95rem;
	}

	.educator-email {
		font-size: 0.82rem;
		color: var(--accent);
		text-decoration: none;
	}
	.educator-email:hover { text-decoration: underline; }

	.educator-hours {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		font-size: 0.875rem;
		color: var(--muted);
	}

	.educator-hours .day {
		display: inline-block;
		width: 5.5rem;
		font-weight: 600;
		color: var(--text);
	}

	/* ── Calendar placeholder ────────────────────────────────────────── */
	.calendar-placeholder {
		width: 100%;
		border-radius: var(--radius-sm);
		overflow: hidden;
		border: 1px solid var(--border);
	}
	.calendar-placeholder svg {
		display: block;
		width: 100%;
		height: auto;
	}

	/* ── Review form ─────────────────────────────────────────────────── */
	.review-form {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.review-form .form-row label {
		display: block;
		font-weight: 600;
		font-size: 0.9rem;
		margin-bottom: 0.4rem;
	}

	.review-form input[type="text"],
	.review-form select,
	.review-form textarea {
		width: 100%;
		max-width: 28rem;
		padding: 0.55rem 0.7rem;
		font: inherit;
		font-size: 0.9rem;
		border: 1.5px solid var(--border);
		border-radius: var(--radius-sm);
		background: rgba(250,250,249,0.9);
		transition: border-color 0.15s;
		outline: none;
	}

	.review-form textarea {
		max-width: 100%;
		resize: vertical;
	}

	.review-form input[type="text"]:focus,
	.review-form select:focus,
	.review-form textarea:focus {
		border-color: #5eead4;
		background: #fff;
	}

	/* ── Rating scale ────────────────────────────────────────────────── */
	.rating-scale {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
		margin-top: 0.4rem;
	}

	.rating-option {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.2rem;
		cursor: pointer;
	}

	.rating-option input[type="radio"] {
		display: none;
	}

	.rating-option__num {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.4rem;
		height: 2.4rem;
		border-radius: 50%;
		border: 2px solid var(--border);
		font-weight: 600;
		font-size: 0.95rem;
		color: var(--muted);
